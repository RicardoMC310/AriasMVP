{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend do MVP SaaS ERP",
  "main": "src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "dotenv -- kysely-codegen --out-file src/platform/database/db.ts",
    "db:migrate": "kysely migrate:latest",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --verbose -c jest.config.unit.mjs --passWithNoTests --detectOpenHandles",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --verbose -c jest.config.integration.mjs --passWithNoTests --detectOpenHandles"
  },
  "keywords": [],
  "author": "RicardoMC310",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.12.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.21.0",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.29.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
