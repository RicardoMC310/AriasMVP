{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend do MVP SaaS ERP",
  "main": "src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --verbose --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:unit": "jest --testPathPatterns='\\.unit\\.test\\.ts$' --passWithNoTests",
    "test:integration": "jest --testPathPatterns='\\.integration\\.test\\.ts$' --passWithNoTests"
  },
  "keywords": [],
  "author": "RicardoMC310",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
